{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["es2020"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": [
    "wrappers/**/*.ts",
    "scripts/**/*.ts",
    "tests/**/*.ts",
    "contracts/**/*.ts",
    "build/**/*.ts"
  ]
}
