# Copy to .env and fill in all values before running

# ── Supabase ──────────────────────────────────────
# Create a project at https://supabase.com, then copy from Project Settings > API
SUPABASE_URL=https://ejghgllyuxefhxbinrdc.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_publishable_hTHnzb_r2k7Lc_F39PyMew_CNIFmjKQ

# ── Auth ──────────────────────────────────────────
# Any random 32+ character string — used to sign JWTs
JWT_SECRET= 7fwe2492p33p320322p34i5fnlkopoor2w
# JWT lifetime (e.g. 7d, 24h, 30d)
JWT_EXPIRES_IN=7d

# ── TON ───────────────────────────────────────────
# Get a free API key at https://toncenter.com
TONCENTER_API_KEY=

# mainnet | testnet
TON_NETWORK=mainnet

# ── TonConnect proof ──────────────────────────────
# Must match the "url" field in public/tonconnect-manifest.json
# Used to validate the proof domain — prevents phishing
ALLOWED_DOMAINS=https://microjobs-nine.vercel.app/,localhost

# How many seconds a TonConnect proof is valid for (300 = 5 minutes)
PROOF_LIFETIME_SECONDS=300

# ── Server ────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── CORS ──────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,https://bountyhive.app
