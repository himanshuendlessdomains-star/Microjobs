# Copy this file to .env.local and fill in the values.

# ─── Supabase (server-side only — never expose these to the browser) ───────────
# Found in: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── App URL (used by TonConnect manifest) ────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://microjobs-nine.vercel.app/

# ─── API base URL ─────────────────────────────────────────────────────────────
# Leave empty — Next.js API routes live on the same origin (no separate backend).
NEXT_PUBLIC_API_URL=

# ─── Escrow address ───────────────────────────────────────────────────────────
# MVP: use a testnet hot-wallet you control (any valid TON address).
# Production: deploy contracts/BountyEscrow.tact and compute per-bounty address.
# See contracts/README.md for the full deployment guide.
NEXT_PUBLIC_ESCROW_ADDRESS=EQAZcvomHFthXG_J8Zagq-K754zUikPj5VCYtLGtUEXOJ2k6
