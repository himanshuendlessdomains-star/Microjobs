# Copy this file to .env.local and fill in the values.

# ─── Supabase (server-side only — never expose these to the browser) ───────────
# Found in: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# ─── App URL (used by TonConnect manifest) ────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://microjobs-nine.vercel.app/

# ─── API base URL ─────────────────────────────────────────────────────────────
# Leave empty — Next.js API routes live on the same origin (no separate backend).
NEXT_PUBLIC_API_URL=
