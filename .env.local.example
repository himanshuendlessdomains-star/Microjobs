# Copy this file to .env.local and fill in the values

# The fully-qualified URL your app is deployed at.
# Used to build the TonConnect manifest URL.
# In development this defaults to http://localhost:3000
NEXT_PUBLIC_APP_URL=https://bountyhive.app

# Backend API base URL (leave blank in dev if you run the backend on :4000)
NEXT_PUBLIC_API_URL=http://localhost:4000
